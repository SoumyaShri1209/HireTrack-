# ─── HireTrack Frontend — Environment Variable Reference ───────────────────
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of the backend API — consumed by api.js (Axios baseURL).
# REQUIRED for both development and production.
VITE_API_BASE_URL=http://localhost:5000/api

# Backend ROOT URL — used only by the Vite dev-server proxy.
# Not needed in production.
VITE_BACKEND_URL=http://localhost:5000

# Google OAuth entry-point URL.
# Must match the route configured in your backend.
VITE_GOOGLE_AUTH_URL=http://localhost:5000/api/auth/google
